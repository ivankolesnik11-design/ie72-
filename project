import tkinter as tk
from PIL import Image, ImageTk
import random
import time

HUMAN_TEMP_LOW = 35.0
HUMAN_TEMP_HIGH = 37.5
ANIMAL_TEMPS = {
    "Корова": {"low": 37.5, "high": 39.5},
    "Курица": {"low": 40.0, "high": 42.0},
    "Баран": {"low": 37.5, "high": 39.5},
    "Свинья": {"low": 38.0, "high": 40.0}
}

class ThermalApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Система Термографии")
        self.root.geometry("800x600")
        self.selected_animal = None
        self.mode = None
        self.main_frame = tk.Frame(root)
        self.main_frame.pack(fill=tk.BOTH, expand=True)
        self.show_initial_selection()

    def show_initial_selection(self):
        for widget in self.main_frame.winfo_children():
            widget.destroy()
        label = tk.Label(self.main_frame, text="Выберите объект наблюдения:", font=("Arial", 16))
        label.pack(pady=20)
        btn_frame = tk.Frame(self.main_frame)
        btn_frame.pack(pady=10)
        btn_human = tk.Button(btn_frame, text="Человек", command=self.select_human, width=15, height=2)
        btn_human.grid(row=0, column=0, padx=10)
        btn_animal = tk.Button(btn_frame, text="Животное", command=self.select_animal_type, width=15, height=2)
        btn_animal.grid(row=0, column=1, padx=10)

    def select_human(self):
        self.mode = 'human'
        self.start_camera_view()

    def select_animal_type(self):
        for widget in self.main_frame.winfo_children():
            widget.destroy()
        label = tk.Label(self.main_frame, text="Выберите животное:", font=("Arial", 16))
        label.pack(pady=20)
        animals = ["Корова", "Курица", "Баран", "Свинья"]
        for animal in animals:
            btn = tk.Button(self.main_frame, text=animal, 
                            command=lambda a=animal: self.start_animal_mode(a),
                            width=20)
            btn.pack(pady=5)
        back_btn = tk.Button(self.main_frame, text="Назад", command=self.show_initial_selection)
        back_btn.pack(side=tk.BOTTOM, pady=10)

    def start_animal_mode(self, animal_name):
        self.selected_animal = animal_name
        self.mode = 'animal'
        self.start_camera_view()

    def start_camera_view(self):
        for widget in self.main_frame.winfo_children():
            widget.destroy()
        self.status_label = tk.Label(self.main_frame, text="Камера активна", font=("Arial", 12))
        self.status_label.pack(pady=5)
        self.canvas = tk.Canvas(self.main_frame, bg="black", width=640, height=480)
        self.canvas.pack(pady=10)
        exit_btn = tk.Button(self.main_frame, text="Вернуться в меню", command=self.show_initial_selection)
        exit_btn.pack(pady=10)

if __name__ == "__main__":
    root = tk.Tk()
    app = ThermalApp(root)
    root.mainloop()
